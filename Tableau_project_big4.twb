      <aliases enabled='yes' />
      <column datatype='real' name='[Audit_Effectiveness_Score]' role='measure' type='quantitative' />
      <column caption='Risk classification' datatype='string' name='[Calculation_1108643254685702]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [High_Risk_Cases] &gt; 250 THEN &apos;HIGH&apos;&#13;&#10;ELSEIF [High_Risk_Cases] &gt; 60 THEN &apos;MEDIUM&apos;&#13;&#10;ELSE &apos;LOW&apos;&#13;&#10;END' />
      </column>
      <column caption='Dimension Risk' datatype='string' name='[Calculation_1108643274293262]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &apos;Firm&apos; THEN [Firm_Name]&#13;&#10;WHEN &apos;Industry&apos; THEN [Industry_Affected]&#13;&#10;END' />
      </column>
      <column caption='Dynamic Measures' datatype='real' name='[Calculation_1108643303030799]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Audit Effectiveness&apos; THEN [Audit_Effectiveness_Score]&#13;&#10;WHEN &apos;Client Satisfaction&apos; THEN [Client_Satisfaction_Score]&#13;&#10;WHEN &apos;Employee Workload&apos; THEN [Employee_Workload]&#13;&#10;WHEN &apos;Fraude Cases&apos; THEN [Fraud_Cases_Detected]&#13;&#10;WHEN &apos;Total Audit&apos; THEN [Total_Audit_Engagements]&#13;&#10;WHEN &apos;Total Revenue Impact&apos; THEN [Total_Revenue_Impact]&#13;&#10;END' />
      </column>
      <column caption='Fraud Ratio: High Risk Firms' datatype='real' name='[Calculation_1108643419570192]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fraud_Cases_Detected])*0.1 / SUM([High_Risk_Cases])' />
      </column>
